#!/bin/sh
# SyncMCP post-commit hook
# Auto-updates file_map.md and flushes session notes after every git commit.
#
# Install: copy this file to .git/hooks/post-commit (or run 'ctx init')

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

if [ -z "$PROJECT_ROOT" ]; then
    exit 0
fi

# Only run if project has a context/ folder
if [ ! -d "$PROJECT_ROOT/context" ]; then
    exit 0
fi

# Update file map (runs in background to not slow commits)
python -m syncmcp.file_mapper "$PROJECT_ROOT" > /dev/null 2>&1 &

# Flush any pending session notes
python -m syncmcp.session --flush "$PROJECT_ROOT" > /dev/null 2>&1 &

exit 0
