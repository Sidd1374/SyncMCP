#!/bin/sh
# SyncMCP post-commit hook — thin shell wrapper that calls the Python hook.
# This file works on macOS/Linux. On Windows, Git for Windows runs the .py directly.

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"

# Try Python hook first (cross-platform)
if command -v python3 >/dev/null 2>&1; then
    python3 "$HOOK_DIR/post-commit.py" 2>/dev/null &
elif command -v python >/dev/null 2>&1; then
    python "$HOOK_DIR/post-commit.py" 2>/dev/null &
fi

exit 0
